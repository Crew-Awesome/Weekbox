{
  "applicationId": "com.genesis.js",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/app/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "enableExtensions": true,
  "tokenSecurity": "one-time",
  "singleInstance": true,
  "nativeAllowList": [
    "app.*",
    "debug.*",
    "os.*",
    "window.*",
    "events.*",
    "filesystem.*",
    "extensions.*",
    "storage.*"
  ],
  "modes": {
    "window": {
      "title": "Genesis Launcher",
      "width": 1280,
      "height": 720,
      "minWidth": 400,
      "minHeight": 200,
      "center": true,
      "enableInspector": true,
      "resizable": true,
      "exitProcessOnClose": true,
      "processArgs": "--disable-web-security",
      "webviewArgs": "--autoplay-policy=no-user-gesture-required --disable-features=PreloadMediaEngagementData,MediaEngagementBypassAutoplayPolicies --disable-web-security"
    }
  },
  "cli": {
    "binaryName": "Genesis Launcher",
    "resourcesPath": "/app/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/app/src/core/native/pc/neutralino.js",
    "binaryVersion": "6.5.0",
    "clientVersion": "6.5.0"
  }
}
